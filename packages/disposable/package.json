{
  "name": "@pvorona/disposable",
  "version": "0.1.2",
  "description": "Disposable teardown coordinator with async completion observation.",
  "keywords": [
    "disposable",
    "dispose",
    "cleanup",
    "teardown",
    "lifecycle",
    "esm"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@pvorona/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.spec.ts",
    "!src/**/*.test.ts",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "test-public-api": "vitest run --config vitest.public-surface.config.mts",
    "typecheck-public-api": "tsc --project tests/consumer/tsconfig.json --noEmit",
    "check-public-surface": "npm run test-public-api && npm run typecheck-public-api && npm run check-package-surface",
    "check-package-surface": "node ./scripts/check-package-surface.mjs",
    "prepublishOnly": "npm run check-package-surface"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pvorona/assert": "~1.0.0",
    "@pvorona/failable": "~0.4.0",
    "@pvorona/noop": "~0.0.1",
    "tslib": "^2.3.0"
  }
}
