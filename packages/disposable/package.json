{
  "name": "@pvorona/disposable",
  "version": "0.0.6",
  "description": "Disposable teardown coordinator with async completion observation.",
  "keywords": [
    "disposable",
    "dispose",
    "cleanup",
    "teardown",
    "lifecycle",
    "esm"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@pvorona/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "check-package-surface": "node ./scripts/check-package-surface.mjs",
    "prepublishOnly": "npm run check-package-surface"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pvorona/assert": "~0.0.2",
    "@pvorona/failable": "~0.2.0",
    "@pvorona/noop": "~0.0.1",
    "tslib": "^2.3.0"
  }
}
