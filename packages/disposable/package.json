{
  "name": "@pvorona/disposable",
  "version": "0.0.6",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "check-package-surface": "node ./scripts/check-package-surface.mjs",
    "prepublishOnly": "npm run check-package-surface"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pvorona/assert": "~0.0.2",
    "@pvorona/failable": "~0.2.0",
    "@pvorona/noop": "~0.0.1",
    "tslib": "^2.3.0"
  }
}
