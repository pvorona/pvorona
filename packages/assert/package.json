{
  "name": "@pvorona/assert",
  "version": "0.1.0",
  "description": "ESM-only TypeScript assertions, restrictive guards, and narrowing helpers.",
  "keywords": [
    "assert",
    "assertion",
    "type-guard",
    "type-narrowing",
    "typescript",
    "esm"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pvorona/pvorona.git",
    "directory": "packages/assert"
  },
  "homepage": "https://github.com/pvorona/pvorona/tree/main/packages/assert#readme",
  "bugs": {
    "url": "https://github.com/pvorona/pvorona/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pvorona/throw-error": "~0.0.2",
    "tslib": "^2.3.0"
  }
}
