{
  "name": "@pvorona/assert",
  "version": "1.0.1",
  "description": "ESM-only TypeScript assertions, restrictive guards, and narrowing helpers.",
  "keywords": [
    "assert",
    "assertion",
    "type-guard",
    "type-narrowing",
    "typescript",
    "esm"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pvorona/pvorona.git",
    "directory": "packages/assert"
  },
  "homepage": "https://github.com/pvorona/pvorona/tree/main/packages/assert#readme",
  "bugs": {
    "url": "https://github.com/pvorona/pvorona/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "test-public-api": "vitest run --config vitest.public-surface.config.mts",
    "typecheck-public-api": "tsc --project tests/consumer/tsconfig.json --noEmit",
    "check-package-surface": "node ./scripts/check-package-surface.mjs",
    "check-public-surface": "npm run test-public-api && npm run typecheck-public-api && npm run check-package-surface",
    "prepublishOnly": "npm run check-public-surface"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pvorona/resolve-value-or-getter": "~0.1.0",
    "@pvorona/throw-error": "~0.0.2"
  }
}
