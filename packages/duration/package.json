{
  "name": "@pvorona/duration",
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "check-consumer-types": "node ./scripts/check-consumer-types.mjs",
    "test-public-api": "vitest run --config vitest.public-surface.config.mts",
    "typecheck-public-api": "npm run check-consumer-types",
    "check-package-surface": "node ./scripts/check-package-surface.mjs",
    "check-public-surface": "npm run test-public-api && npm run typecheck-public-api && npm run check-package-surface",
    "prepublishOnly": "npm run check-public-surface"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pvorona/assert": "~0.1.0"
  }
}
