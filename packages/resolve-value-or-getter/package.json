{
  "name": "@pvorona/resolve-value-or-getter",
  "version": "0.1.0",
  "description": "Resolve a literal value or lazily compute it from a zero-argument getter.",
  "keywords": [
    "typescript",
    "esm",
    "getter",
    "lazy",
    "utility"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pvorona/pvorona.git",
    "directory": "packages/resolve-value-or-getter"
  },
  "homepage": "https://github.com/pvorona/pvorona/tree/main/packages/resolve-value-or-getter#readme",
  "bugs": {
    "url": "https://github.com/pvorona/pvorona/issues"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@pvorona/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "test-public-api": "vitest run --config vitest.public-surface.config.mts",
    "typecheck-public-api": "tsc --project tests/consumer/tsconfig.json --noEmit",
    "check-package-surface": "node ./scripts/check-package-surface.mjs",
    "check-public-surface": "npm run test-public-api && npm run typecheck-public-api && npm run check-package-surface",
    "prepublishOnly": "npm run check-public-surface"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {}
}
