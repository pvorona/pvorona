{
  "name": "@pvorona/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "precommit": "lint-staged"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@faker-js/faker": "^10.3.0",
    "@nx/eslint": "22.5.1",
    "@nx/eslint-plugin": "22.5.1",
    "@nx/js": "22.5.1",
    "@nx/vite": "22.5.1",
    "@nx/vitest": "22.5.1",
    "@nx/web": "22.5.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
    "@vitest/coverage-v8": "4.0.9",
    "@vitest/ui": "4.0.9",
    "acorn": "^8.16.0",
    "ajv": "^8.0.0",
    "eslint": "~8.57.0",
    "expect-type": "^1.3.0",
    "husky": "^9.1.7",
    "jiti": "2.4.2",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^16.4.0",
    "nx": "22.5.1",
    "prettier": "^2.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "verdaccio": "^6.0.5",
    "vite": "^7.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "4.0.9"
  },
  "workspaces": [
    "packages/*"
  ],
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
